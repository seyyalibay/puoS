# SkillPulse ortam değişkenleri — ÖRNEK ŞABLON.
# Bu dosyayı kopyalayıp `.env` olarak kaydet ve değerleri kendi key'lerinle doldur:
#   cp .env.example .env
# .env dosyası git'e EKLENMEZ (.gitignore'da).

# Jooble key'leri ÜLKE SİTESİNE bağlıdır — her ülke için ayrı key gerekir.
# US: https://jooble.org/api/about · TR: https://tr.jooble.org/api/about
JOOBLE_API_KEY_US=
JOOBLE_API_KEY_TR=

# Adzuna (UK ilanları) — https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Careerjet TR (ek kaynak — tam description) — https://www.careerjet.com.tr/partners/
CAREERJET_API_KEY=

# Gemini (öneriler sekmesi) — https://aistudio.google.com/apikey
# Birincil key'in kotası dolarsa istek otomatik olarak _2.._6 yedek key'lerle denenir.
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GEMINI_API_KEY_6=

# Groq — Gemini'nin TÜM key'leri başarısız olursa (504/kota) analizi bu üretir.
# OpenAI-uyumlu endpoint. https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# rakip_zekasi.py için (opsiyonel — harici otonom-git projesi)
GITHUB_TOKEN=
GNEWS_API_KEY=
